# VITE_API_URL: URL base da API backend (vip-car-api).
# Em desenvolvimento, aponta para localhost.
# Em produção (Vercel), configure essa variável no painel do Vercel.
VITE_API_URL=https://vip-car-api.vercel.app

# GEMINI_API_KEY: Necessária para chamadas de IA (leitura de placas, etc).
# Configure no painel do Vercel como variável de ambiente.
GEMINI_API_KEY=sua_gemini_api_key_aqui
